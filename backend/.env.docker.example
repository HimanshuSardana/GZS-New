# Copy this file to .env.docker and fill in real values before starting Docker.
# Run: docker compose --env-file .env.docker up -d
# NEVER commit .env.docker — it is listed in .gitignore.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=Gzone@2025

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=gzs_mongo
MONGO_ROOT_PASSWORD=change_me_in_production

# ── Full DATABASE_URL per service ──────────────────────────────────────────────
# The @ in the password must be URL-encoded as %40.
CORE_DATABASE_URL=postgresql://gzs_core_user:Gzone%402025@postgres:5432/GzoneSphere
CMS_DATABASE_URL=postgres://gzs_cms_user:Gzone%402025@postgres:5432/GzoneSphere?sslmode=disable

# ── MongoDB connection string ──────────────────────────────────────────────────
# Must match MONGO_ROOT_USER / MONGO_ROOT_PASSWORD above.
MONGO_URL=mongodb://gzs_mongo:change_me_in_production@mongodb:27017/gzonesphere?authSource=admin
MONGO_DB_NAME=gzonesphere
