# GzoneSphere Frontend — copy this file to .env.local and adjust values

# Set to true to use local mock data (no backend needed)
VITE_USE_MOCK=false

# Dev persona bypass — AuthProvider uses dummy personas in dev by default (no backend required).
# Set to true to disable the bypass and hit the real API even during `vite dev`.
VITE_REAL_AUTH=false

# Core API (Python FastAPI) — handles auth, profiles, tournaments, community
VITE_CORE_API_URL=http://localhost:8000

# CMS API (Go Gin) — handles games, blogs, gameposts.
# Docker mode (default): keep as /api/cms — the Vite dev server proxies /api/cms → localhost:8001.
# Direct mode (no Docker, Go app on :8080): change to http://localhost:8080/api/cms.
VITE_CMS_API_URL=/api/cms

# Production overrides:
# VITE_CORE_API_URL=https://api.gzonesphere.com
# VITE_CMS_API_URL=https://api.gzonesphere.com/api/cms
