# GzoneSphere Frontend — Production build-arg reference
#
# Every VITE_* variable listed here MUST be supplied as a Docker build-arg
# (or repository secret) before running `docker compose build frontend` or the
# GitHub Actions `frontend-build` job.
#
# These values are baked into the JS bundle at build time by Vite.
# Changing them requires a full rebuild — they are NOT runtime env vars.
#
# Copy this file, fill in real values, and supply via:
#   docker compose --env-file .env.production build frontend
#
# ─────────────────────────────────────────────────────────────────────────────

# Mock data — must be false in production.
# Setting to true causes the vite-plugin-mock-guard plugin to throw at build time.
VITE_USE_MOCK=false

# Real-auth bypass — must be true in production so the login form hits the API.
VITE_REAL_AUTH=true

# Core API (Python / FastAPI) — handles auth, profiles, tournaments, community.
# Docker Compose default:  /api/core  (proxied through nginx — no absolute URL needed)
# Standalone deployment:   https://api.gzonesphere.com
VITE_CORE_API_URL=/api/core

# CMS API (Go / Gin) — handles games, blogs, gameposts.
# Docker Compose default:  /api/cms   (proxied through nginx)
# Standalone deployment:   https://api.gzonesphere.com/api/cms
VITE_CMS_API_URL=/api/cms
