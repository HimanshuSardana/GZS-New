{
  "name": "gzone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently --names \"CORE,CMS,FRONT\" --prefix-colors \"cyan,yellow,magenta\" \"npm run dev:core\" \"npm run dev:cms\" \"npm run dev:front\"",
    "dev:front": "vite",
    "dev:core": "cd backend/core-api && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:cms": "cd backend/cms-api && go run .",
    "install:all": "npm install && pip install -r backend/core-api/requirements.txt && cd backend/cms-api && go mod download",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.13.6",
    "framer-motion": "^12.38.0",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  }
}
